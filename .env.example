# ---- Supabase ----
# Get these from https://app.supabase.com -> your project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# ---- Stripe ----
# Get these from https://dashboard.stripe.com/apikeys (start in test mode)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ---- Resend (transactional email) ----
# https://resend.com/api-keys  — free tier is enough to start
RESEND_API_KEY=re_...
RESEND_FROM="ProblemMarket <hello@problemamvp.vercel.app>"

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://problemamvp.vercel.app

# ---- Admin gating ----
# Comma-separated list of emails that get /admin access. Start with just yours.
ADMIN_EMAILS=peterfugleberg04@gmail.com
